    app:category "metabolic" .

param:BMI
    a app:BiomarkerParameter ;
    rdfs:label "Body Mass Index" ;
    app:prologName "bmi" ;
    app:loincCode "39156-5" ;
    app:snomedObservable snomed:60621009 ;
    app:ucumUnit "kg/m2" ;
    app:normalRangeLow "18.5"^^xsd:decimal ;
    app:normalRangeHigh "24.9"^^xsd:decimal ;
    app:category "metabolic" .


