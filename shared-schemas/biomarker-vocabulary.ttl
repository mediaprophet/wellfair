    app:ucumUnit "nmol/L" ;
    app:normalRangeLow "50.0"^^xsd:decimal ;
    app:normalRangeHigh "250.0"^^xsd:decimal ;
    app:category "endocrine" ;
    rdfs:comment "Deficiency (<50 nmol/L) associated with bone disease, immune dysfunction, depression. Particularly relevant for EDS and chronic pain populations." .


# =============================================================================
# PSYCHIATRIC / PSYCHOSOCIAL
# =============================================================================

param:PHQ9
    a app:BiomarkerParameter ;
    rdfs:label "PHQ-9 Depression Score" ;
    app:prologName "phq9_score" ;
    app:loincCode "44261-6" ;
    app:ucumUnit "{score}" ;
    app:normalRangeLow "0.0"^^xsd:decimal ;
    app:normalRangeHigh "4.0"^^xsd:decimal ;
    app:category "psychiatric" ;
    rdfs:comment "0–4 minimal, 5–9 mild, 10–14 moderate, 15–19 moderately severe, 20–27 severe." .

param:GAD7
    a app:BiomarkerParameter ;
    rdfs:label "GAD-7 Anxiety Score" ;
    app:prologName "gad7_score" ;
    app:loincCode "69737-5" ;
    app:ucumUnit "{score}" ;
    app:normalRangeLow "0.0"^^xsd:decimal ;
    app:normalRangeHigh "4.0"^^xsd:decimal ;
    app:category "psychiatric" ;
    rdfs:comment "0–4 minimal, 5–9 mild, 10–14 moderate, 15–21 severe." .

param:PCL5
    a app:BiomarkerParameter ;
    rdfs:label "PCL-5 PTSD Symptom Score" ;
    app:prologName "pcl5_score" ;
    app:loincCode "97974-3" ;
    app:ucumUnit "{score}" ;
    app:normalRangeLow "0.0"^^xsd:decimal ;
    app:normalRangeHigh "31.0"^^xsd:decimal ;
    app:category "psychiatric" ;
    rdfs:comment "Probable PTSD: ≥31–33. Used with trauma history to trigger PTSD implication rules." .

param:SleepEfficiency
    a app:BiomarkerParameter ;
    rdfs:label "Sleep Efficiency" ;
    app:prologName "sleep_efficiency" ;
    app:loincCode "93832-4" ;
    app:ucumUnit "%" ;
    app:normalRangeLow "85.0"^^xsd:decimal ;
    app:normalRangeHigh "100.0"^^xsd:decimal ;
    app:category "psychiatric" .


# =============================================================================
# SOCIAL DETERMINANTS (non-clinical parameters for welfare rulesets)
# =============================================================================

param:HousingStability
    a app:BiomarkerParameter ;
    rdfs:label "Housing Stability Index" ;
    app:prologName "housing_stability" ;
    app:ucumUnit "{score}" ;
    app:normalRangeLow "70.0"^^xsd:decimal ;
    app:normalRangeHigh "100.0"^^xsd:decimal ;
    app:category "social" ;
    rdfs:comment "0 = street homeless, 100 = stable owned housing. Welfare ruleset parameter." .

param:WeeklyIncome
    a app:BiomarkerParameter ;
    rdfs:label "Weekly Net Income (AUD)" ;
    app:prologName "weekly_income_aud" ;
    app:ucumUnit "[AUD]" ;
    app:category "social" ;
    rdfs:comment "Used in welfare eligibility rulesets for income threshold testing." .

param:SocialIsolationScore
    a app:BiomarkerParameter ;
    rdfs:label "Social Isolation Score (UCLA-3)" ;
    app:prologName "social_isolation" ;
    app:ucumUnit "{score}" ;
    app:normalRangeLow "3.0"^^xsd:decimal ;
    app:normalRangeHigh "5.0"^^xsd:decimal ;
    app:category "social" ;
    rdfs:comment "3–5 not isolated, 6–9 moderate isolation. Elevated score linked to cardiovascular risk and cognitive decline." .
