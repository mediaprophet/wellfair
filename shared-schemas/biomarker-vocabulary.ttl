    app:loincCode "2089-1" ;
    app:snomedObservable snomed:113079009 ;
    app:ucumUnit "mmol/L" ;
    app:normalRangeLow "0.0"^^xsd:decimal ;
    app:normalRangeHigh "3.0"^^xsd:decimal ;
    app:category "metabolic" .

param:HDL
    a app:BiomarkerParameter ;
    rdfs:label "HDL Cholesterol" ;
    app:prologName "hdl" ;
    app:loincCode "2085-9" ;
    app:snomedObservable snomed:102737005 ;
    app:ucumUnit "mmol/L" ;
    app:normalRangeLow "1.0"^^xsd:decimal ;
    app:normalRangeHigh "3.0"^^xsd:decimal ;
    app:category "metabolic" .

param:Triglycerides
    a app:BiomarkerParameter ;
    rdfs:label "Triglycerides" ;
    app:prologName "triglycerides" ;
    app:loincCode "2571-8" ;
    app:snomedObservable snomed:85600001 ;
    app:ucumUnit "mmol/L" ;
    app:normalRangeLow "0.0"^^xsd:decimal ;
