    app:prologName "cortisol_am" ;
    app:loincCode "2143-6" ;
    app:snomedObservable snomed:42186007 ;
    app:ucumUnit "nmol/L" ;
    app:normalRangeLow "170.0"^^xsd:decimal ;
    app:normalRangeHigh "540.0"^^xsd:decimal ;
    app:category "endocrine" ;
    rdfs:comment "HPA-axis marker. Dysregulated in PTSD, chronic stress, adrenal insufficiency." .

param:Insulin
    a app:BiomarkerParameter ;
    rdfs:label "Fasting Serum Insulin" ;
    app:prologName "fasting_insulin" ;
    app:loincCode "20448-7" ;
    app:ucumUnit "pmol/L" ;
    app:normalRangeLow "18.0"^^xsd:decimal ;
