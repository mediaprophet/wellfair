# =============================================================================
# WellFair – Biomarker Parameter Vocabulary
# =============================================================================
# Maps Prolog parameter names (used in compiled .pl rule files) to LOINC
# codes, SNOMED observable entities, units, and normal reference ranges.
#
# Purpose: interoperability bridge between:
#   - SPARQL-to-Prolog fact bridge (user_metric/3 assertions)
#   - FHIR Observation resources (LOINC-coded lab results)
#   - Expert-authored Prolog rules (which reference prolog_name strings)
#
# When a user's data arrives from a FHIR source using LOINC codes, the
# bridge uses this vocabulary to resolve the correct Prolog parameter name.
# =============================================================================

@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .

@prefix loinc:  <http://loinc.org/> .
@prefix snomed: <http://snomed.info/id/> .
@prefix ucum:   <http://unitsofmeasure.org/> .

@prefix app:    <https://wellfair.app/ontology/> .
@prefix param:  <https://wellfair.app/biomarker/> .


# =============================================================================
# ONTOLOGY METADATA
# =============================================================================

<https://wellfair.app/ontology/biomarker-vocabulary>
    a owl:Ontology ;
    rdfs:label "WellFair Biomarker Parameter Vocabulary" ;
    rdfs:comment "Bridges Prolog parameter names to LOINC codes and clinical reference ranges." ;
    owl:versionInfo "0.1.0" .


# =============================================================================
# SCHEMA
# =============================================================================

app:BiomarkerParameter
    a rdfs:Class ;
    rdfs:label "Biomarker Parameter" ;
    rdfs:comment "A measurable biological or clinical variable used as a trigger condition in Prolog rules." .

app:prologName
    a rdf:Property ;
    rdfs:label "Prolog parameter name" ;
    rdfs:comment "The atom name used in user_metric(User, <name>, Value) Prolog assertions." ;
    rdfs:domain app:BiomarkerParameter ;
    rdfs:range  xsd:string .

app:loincCode
    a rdf:Property ;
    rdfs:label "LOINC code" ;
    rdfs:comment "The LOINC observation code for this parameter." ;
    rdfs:domain app:BiomarkerParameter ;
    rdfs:range  xsd:string .

app:snomedObservable
    a rdf:Property ;
    rdfs:label "SNOMED observable entity" ;
    rdfs:comment "SNOMED CT URI for the observable entity." ;
    rdfs:domain app:BiomarkerParameter ;
    rdfs:range  rdfs:Resource .

app:ucumUnit
    a rdf:Property ;
    rdfs:label "UCUM unit" ;
    rdfs:comment "Unified Code for Units of Measure (UCUM) string." ;
    rdfs:domain app:BiomarkerParameter ;
    rdfs:range  xsd:string .

app:normalRangeLow
    a rdf:Property ;
    rdfs:label "normal range lower bound" ;
    rdfs:domain app:BiomarkerParameter ;
    rdfs:range  xsd:decimal .

app:normalRangeHigh
    a rdf:Property ;
    rdfs:label "normal range upper bound" ;
    rdfs:domain app:BiomarkerParameter ;
    rdfs:range  xsd:decimal .

app:category
    a rdf:Property ;
    rdfs:label "biomarker category" ;
    rdfs:comment "Broad grouping: metabolic | cardiovascular | renal | hepatic | haematology | endocrine | psychiatric | social" ;
    rdfs:domain app:BiomarkerParameter ;
    rdfs:range  xsd:string .


# =============================================================================
# METABOLIC
# =============================================================================

param:HbA1c
    a app:BiomarkerParameter ;
    rdfs:label "Glycated Haemoglobin (HbA1c)" ;
    app:prologName "hba1c" ;
    app:loincCode "4548-4" ;
    app:snomedObservable snomed:43396009 ;
    app:ucumUnit "%" ;
    app:normalRangeLow "4.0"^^xsd:decimal ;
    app:normalRangeHigh "5.6"^^xsd:decimal ;
    app:category "metabolic" ;
    rdfs:comment "Primary diabetes monitoring marker. Prediabetes: 5.7–6.4%. Diabetes: ≥6.5%." .

param:FastingGlucose
    a app:BiomarkerParameter ;
    rdfs:label "Fasting Plasma Glucose" ;
    app:prologName "fasting_glucose" ;
    app:loincCode "1558-6" ;
    app:snomedObservable snomed:33747003 ;
    app:ucumUnit "mmol/L" ;
    app:normalRangeLow "3.9"^^xsd:decimal ;
    app:normalRangeHigh "5.5"^^xsd:decimal ;
    app:category "metabolic" .

param:TotalCholesterol
    a app:BiomarkerParameter ;
    rdfs:label "Total Cholesterol" ;
    app:prologName "total_cholesterol" ;
    app:loincCode "2093-3" ;
    app:snomedObservable snomed:121868005 ;
    app:ucumUnit "mmol/L" ;
    app:normalRangeLow "0.0"^^xsd:decimal ;
    app:normalRangeHigh "5.0"^^xsd:decimal ;
    app:category "metabolic" .

