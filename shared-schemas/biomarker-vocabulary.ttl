    app:normalRangeLow "13.5"^^xsd:decimal ;
    app:normalRangeHigh "17.5"^^xsd:decimal ;
    app:category "haematology" ;
    rdfs:comment "Normal range is sex-dependent; values here are for adult males." .

param:WBC
    a app:BiomarkerParameter ;
    rdfs:label "White Blood Cell Count" ;
    app:prologName "wbc" ;
    app:loincCode "6690-2" ;
    app:snomedObservable snomed:767002 ;
