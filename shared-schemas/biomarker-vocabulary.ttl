    app:normalRangeHigh "120.0"^^xsd:decimal ;
    app:category "renal" ;
    rdfs:comment "CKD staging: G1 ≥90, G2 60–89, G3a 45–59, G3b 30–44, G4 15–29, G5 <15." .

