param:DiastolicBP
    a app:BiomarkerParameter ;
    rdfs:label "Diastolic Blood Pressure" ;
    app:prologName "diastolic_bp" ;
    app:loincCode "8462-4" ;
    app:snomedObservable snomed:271650006 ;
    app:ucumUnit "mm[Hg]" ;
    app:normalRangeLow "60.0"^^xsd:decimal ;
    app:normalRangeHigh "80.0"^^xsd:decimal ;
