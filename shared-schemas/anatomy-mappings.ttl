# =============================================================================
# SEVERITY WEIGHT DEFINITIONS (for Prolog and visualiser)
# =============================================================================

app:SeverityHigh
    a rdfs:Resource ;
    skos:notation "high" ;
    rdfs:label "High severity" ;
    rdfs:comment "Primary target; strong causal evidence. Render red (#ff3333) at emissiveIntensity 0.9." .

app:SeverityMedium
    a rdfs:Resource ;
    skos:notation "medium" ;
    rdfs:label "Medium severity" ;
    rdfs:comment "Secondary target; indirect or cumulative mechanism. Render amber (#ffaa00) at emissiveIntensity 0.6." .

app:SeverityLow
    a rdfs:Resource ;
    skos:notation "low" ;
    rdfs:label "Low severity" ;
    rdfs:comment "Tertiary or conditional target; contextual risk. Render yellow (#ffffaa) at emissiveIntensity 0.3." .
