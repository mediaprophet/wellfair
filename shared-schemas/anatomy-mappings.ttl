# =============================================================================
# WellFair – Spatial-Semantic Anatomy Mappings
# =============================================================================
# Bridges Three.js mesh node names (from HuBMAP CCF GLBs and procedural
# geometry) to authoritative biomedical ontology URIs.
#
# Mesh IDs match the .name property of nodes inside the HuBMAP CCF GLBs
# as they appear in the Three.js scene graph (scene.getObjectByName()).
# HuBMAP GLB naming follows: <Institution>_<Sex>_<Organ>[_<Laterality>]
#
# Ontologies used:
#   FMA   – Foundational Model of Anatomy (structural definitions)
#   UBERON– Uber-anatomy ontology (cross-species bridge; from HuBMAP manifest)
#   SNOMED– SNOMED CT (clinical conditions and pathologies)
#   HP    – Human Phenotype Ontology (phenotypic abnormalities)
#   app:  – WellFair application schema (glue vocabulary)
#
# Sources:
#   HuBMAP CCF 3D Reference Object Library (CC BY 4.0)
#   https://github.com/hubmapconsortium/ccf-3d-reference-object-library
# =============================================================================

@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .

@prefix fma:    <http://purl.org/sig/ont/fma/> .
@prefix uberon: <http://purl.obolibrary.org/obo/UBERON_> .
@prefix snomed: <http://snomed.info/id/> .
@prefix hp:     <http://purl.obolibrary.org/obo/HP_> .

@prefix app:    <https://wellfair.app/ontology/> .
@prefix asset:  <https://wellfair.app/asset/> .
@prefix cond:   <https://wellfair.app/condition/> .


# =============================================================================
# ONTOLOGY METADATA
# =============================================================================

<https://wellfair.app/ontology/anatomy-mappings>
    a owl:Ontology ;
    rdfs:label "WellFair Anatomy Mappings" ;
    rdfs:comment "Maps WebGL mesh node IDs from HuBMAP CCF assets to FMA/UBERON anatomical URIs, and links clinical conditions to their implicated anatomical targets." ;
    owl:versionInfo "0.1.0" .


# =============================================================================
# SCHEMA: CLASSES
# =============================================================================

app:3DMeshElement
    a rdfs:Class ;
    rdfs:label "3D Mesh Element" ;
    rdfs:comment "A named node in a WebGL scene graph (Three.js) corresponding to an anatomical structure." .

app:AnatomicalSystem
    a rdfs:Class ;
    rdfs:label "Anatomical System" ;
    rdfs:comment "A named body system grouping one or more mesh elements (e.g. cardiovascular, nervous)." .

app:ClinicalImplication
    a rdfs:Class ;
    rdfs:label "Clinical Implication" ;
    rdfs:comment "A directional assertion that a given condition stresses or pathologically implicates one or more anatomical structures, with a severity weight." .


# =============================================================================
# SCHEMA: PROPERTIES
# =============================================================================

app:hasMeshId
    a rdf:Property ;
    rdfs:label "has mesh ID" ;
    rdfs:comment "The Three.js scene node name (mesh.name) used by scene.getObjectByName()." ;
    rdfs:domain app:3DMeshElement ;
    rdfs:range  xsd:string .

app:hasGlbFile
    a rdf:Property ;
    rdfs:label "has GLB file" ;
    rdfs:comment "Local filename of the source GLB asset (relative to static/models/hra/)." ;
    rdfs:domain app:3DMeshElement ;
    rdfs:range  xsd:string .

app:mapsToAnatomy
    a rdf:Property ;
    rdfs:label "maps to anatomy" ;
    rdfs:comment "Links a mesh element to its FMA anatomical structure URI." ;
    rdfs:domain app:3DMeshElement ;
    rdfs:range  fma:Anatomical_structure .

app:mapsToUberon
    a rdf:Property ;
    rdfs:label "maps to UBERON" ;
    rdfs:comment "Cross-reference to UBERON identifier (from HuBMAP manifest)." ;
    rdfs:domain app:3DMeshElement ;
    rdfs:range  rdfs:Resource .

app:inSystem
    a rdf:Property ;
    rdfs:label "in system" ;
    rdfs:comment "Assigns a mesh element to a named anatomical system layer." ;
    rdfs:domain app:3DMeshElement ;
    rdfs:range  app:AnatomicalSystem .

app:impliesPathologyIn
    a rdf:Property ;
    rdfs:label "implies pathology in" ;
    rdfs:comment "Asserts that a clinical condition has documented pathological implications for a given anatomical structure." ;
    rdfs:domain rdfs:Resource ;
    rdfs:range  fma:Anatomical_structure .

app:severityWeight
    a rdf:Property ;
    rdfs:label "severity weight" ;
    rdfs:comment "Qualitative severity of the implication: high | medium | low." ;
    rdfs:range  xsd:string .

app:evidenceSource
    a rdf:Property ;
    rdfs:label "evidence source" ;
    rdfs:comment "DOI or URL of the peer-reviewed study supporting this implication." ;
    rdfs:range  xsd:anyURI .

app:highlightColor
    a rdf:Property ;
    rdfs:label "highlight color" ;
    rdfs:comment "Suggested hex color for WebGL emissive highlight at this severity." ;
    rdfs:range  xsd:string .

app:forCondition
    a rdf:Property ;
    rdfs:label "for condition" ;
    rdfs:comment "Links a ClinicalImplication to the SNOMED-CT condition URI it describes." ;
    rdfs:domain app:ClinicalImplication ;
    rdfs:range  rdfs:Resource .


# =============================================================================
# ANATOMICAL SYSTEMS (Layer identifiers matching Three.js layer names)
# =============================================================================

asset:System_Cardiovascular
    a app:AnatomicalSystem ;
    rdfs:label "Cardiovascular System" ;
    skos:notation "cardio" .          # matches layers['cardio'] in anatomy_3d.py

asset:System_Nervous
    a app:AnatomicalSystem ;
    rdfs:label "Nervous System" ;
    skos:notation "nervous" .

asset:System_Endocrine
    a app:AnatomicalSystem ;
    rdfs:label "Endocrine System" ;
    skos:notation "endocrine" .

asset:System_Respiratory
    a app:AnatomicalSystem ;
    rdfs:label "Respiratory System" ;
    skos:notation "respiratory" .

asset:System_Urinary
    a app:AnatomicalSystem ;
    rdfs:label "Urinary System" ;
    skos:notation "urinary" .

asset:System_Digestive
    a app:AnatomicalSystem ;
    rdfs:label "Digestive System" ;
    skos:notation "digestive" .

asset:System_Immune
    a app:AnatomicalSystem ;
    rdfs:label "Immune / Lymphatic System" ;
    skos:notation "immune" .

asset:System_Skeletal
    a app:AnatomicalSystem ;
    rdfs:label "Skeletal System" ;
    skos:notation "skeletal" .

asset:System_Muscular
    a app:AnatomicalSystem ;
    rdfs:label "Muscular System" ;
    skos:notation "muscular" .

asset:System_Integumentary
    a app:AnatomicalSystem ;
    rdfs:label "Integumentary (Skin) System" ;
    skos:notation "skin" .


# =============================================================================
# MESH MAPPINGS: CARDIOVASCULAR
# HuBMAP assets: organ_heart_m.glb, organ_vasculature_m.glb
# Internal node names derived from HuBMAP CCF GLB scene graph conventions.
# =============================================================================

asset:Mesh_Heart
    a app:3DMeshElement ;
    rdfs:label "Heart" ;
    app:hasMeshId "VH_M_Heart" ;
    app:hasGlbFile "organ_heart_m.glb" ;
    app:mapsToAnatomy fma:Heart ;
    app:mapsToUberon uberon:0000948 ;
    app:inSystem asset:System_Cardiovascular .

asset:Mesh_Blood_Vasculature
    a app:3DMeshElement ;
    rdfs:label "Blood Vasculature Network" ;
    app:hasMeshId "VH_M_Blood_Vasculature" ;
    app:hasGlbFile "organ_vasculature_m.glb" ;
    app:mapsToAnatomy fma:Cardiovascular_system ;
    app:mapsToUberon uberon:0004537 ;
    app:inSystem asset:System_Cardiovascular .

# Procedural geometry (anatomy_3d.py: sysCardio group)
# These use programmatic Three.js mesh objects without HuBMAP source files.
# To make them resolvable, assign .name in Three.js before adding to scene.
asset:Mesh_Heart_Procedural
    a app:3DMeshElement ;
    rdfs:label "Heart (procedural)" ;
    app:hasMeshId "proc_heart" ;
    app:mapsToAnatomy fma:Heart ;
    app:mapsToUberon uberon:0000948 ;
    app:inSystem asset:System_Cardiovascular .

asset:Mesh_Aorta_Procedural
    a app:3DMeshElement ;
    rdfs:label "Aorta (procedural)" ;
    app:hasMeshId "proc_aorta" ;
    app:mapsToAnatomy fma:Aorta ;
    app:inSystem asset:System_Cardiovascular .

# Sub-vessel mappings (resolved by SPARQL for condition implications)
asset:Mesh_Renal_Artery_Left
    a app:3DMeshElement ;
    rdfs:label "Left Renal Artery" ;
    app:hasMeshId "VH_M_Renal_Artery_L" ;
    app:mapsToAnatomy fma:Left_renal_artery ;
    app:inSystem asset:System_Cardiovascular .

asset:Mesh_Renal_Artery_Right
    a app:3DMeshElement ;
    rdfs:label "Right Renal Artery" ;
    app:hasMeshId "VH_M_Renal_Artery_R" ;
    app:mapsToAnatomy fma:Right_renal_artery ;
    app:inSystem asset:System_Cardiovascular .

asset:Mesh_Coronary_Artery_Left
    a app:3DMeshElement ;
    rdfs:label "Left Coronary Artery" ;
    app:hasMeshId "VH_M_Coronary_L" ;
    app:mapsToAnatomy fma:Left_coronary_artery ;
    app:inSystem asset:System_Cardiovascular .

asset:Mesh_Coronary_Artery_Right
