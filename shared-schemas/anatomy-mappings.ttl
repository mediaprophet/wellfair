# =============================================================================
# CONDITION → ANATOMY IMPLICATION SETS
#
# These triples are the primary input consumed by the SWI-Prolog reasoning
# engine and the SPARQL mesh resolver. Each implication block links a SNOMED
# condition to the FMA anatomical structures it pathologically stresses, with
# a severity weight.
#
# Prolog rules compiled from these blocks take the form:
#   implication_target(User, <fma-uri>, Severity) :-
#       user_fact(User, <snomed-uri>), <biomarker conditions>.
# =============================================================================

# -----------------------------------------------------------------------------
# DIABETES MELLITUS TYPE 2 (SNOMED: 44054006)
# Major systemic microvascular and macrovascular complications.
# -----------------------------------------------------------------------------

cond:Diabetes_T2_Implication_Retina
    a app:ClinicalImplication ;
    rdfs:label "Diabetic retinopathy – retinal microvasculature" ;
    app:forCondition snomed:44054006 ;
    app:impliesPathologyIn fma:Retina ;
    app:severityWeight "high" ;
    app:highlightColor "#ff3333" .

cond:Diabetes_T2_Implication_Kidney
    a app:ClinicalImplication ;
    rdfs:label "Diabetic nephropathy – renal filtration units" ;
    app:forCondition snomed:44054006 ;
    app:impliesPathologyIn fma:Left_kidney, fma:Right_kidney,
                            fma:Left_renal_artery, fma:Right_renal_artery ;
    app:severityWeight "high" ;
    app:highlightColor "#ff3333" .

cond:Diabetes_T2_Implication_Pancreas
    a app:ClinicalImplication ;
    rdfs:label "Beta-cell dysfunction – islets of Langerhans" ;
    app:forCondition snomed:44054006 ;
    app:impliesPathologyIn fma:Pancreas ;
    app:severityWeight "high" ;
    app:highlightColor "#ff3333" .

cond:Diabetes_T2_Implication_Peripheral_Vascular
    a app:ClinicalImplication ;
    rdfs:label "Peripheral arterial disease – distal vasculature" ;
    app:forCondition snomed:44054006 ;
    app:impliesPathologyIn fma:Cardiovascular_system ;
    app:severityWeight "medium" ;
    app:highlightColor "#ffaa00" .

cond:Diabetes_T2_Implication_Nervous
    a app:ClinicalImplication ;
    rdfs:label "Peripheral neuropathy – distal nerve fibres" ;
    app:forCondition snomed:44054006 ;
    app:impliesPathologyIn fma:Spinal_cord ;
    app:severityWeight "medium" ;
    app:highlightColor "#ffaa00" .


# -----------------------------------------------------------------------------
# ESSENTIAL HYPERTENSION (SNOMED: 59621000)
# -----------------------------------------------------------------------------

cond:Hypertension_Implication_Heart
    a app:ClinicalImplication ;
    rdfs:label "Left ventricular hypertrophy – myocardium" ;
    app:forCondition snomed:59621000 ;
    app:impliesPathologyIn fma:Heart, fma:Left_coronary_artery, fma:Right_coronary_artery ;
    app:severityWeight "high" ;
    app:highlightColor "#ff3333" .

cond:Hypertension_Implication_Kidney
    a app:ClinicalImplication ;
    rdfs:label "Hypertensive nephropathy – renal arterioles" ;
    app:forCondition snomed:59621000 ;
    app:impliesPathologyIn fma:Left_kidney, fma:Right_kidney,
                            fma:Left_renal_artery, fma:Right_renal_artery ;
    app:severityWeight "high" ;
